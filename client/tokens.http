### Get access and refresh tokens for an admin user
POST http://localhost:8000/api/token/
Content-Type: application/json

{
  "username": "admin",
  "password": "thisistheadminpassword"
}


### Refresh the access token
POST http://localhost:8000/api/token/refresh/
Content-Type: application/json

{
  "refresh": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJ0b2tlbl90eXBlIjoicmVmcmVzaCIsImV4cCI6MTczNTU3OTk1OSwiaWF0IjoxNzM1MTQ3OTU5LCJqdGkiOiI5MmY5NzQzNWIxOTA0ZDI4YTgzNzNmNDI3MjkyNTUzNiIsInVzZXJfaWQiOjh9.mqkbRkc1aHNlmJxA11_HANjsqzk5iM7gt0haCLM5oEo"
